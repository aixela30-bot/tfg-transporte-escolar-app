<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTituloGps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚌 Ruta Escolar"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mungia - Larramendi Ikastola"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="18dp" />

        <FrameLayout
            android:id="@+id/contenedorMapa"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/imgMapa"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/mapa_ruta" />

            <TextView
                android:id="@+id/pinMapa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="32sp" />

        </FrameLayout>

        <TextView
            android:id="@+id/txtEstadoRuta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado de ruta: En curso"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/txtUbicacionActual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Ubicación actual: Aeropuerto de Bilbao"
            android:textSize="18sp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/txtDestino"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Destino: Larramendi Ikastola"
            android:textSize="18sp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/txtMenores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👧 Menores a bordo: 12"
            android:textSize="18sp"
            android:layout_marginBottom="28dp" />

        <Button
            android:id="@+id/btnActualizarGps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Actualizar ubicación"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#673AB7" />

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volver"
            android:textSize="18sp"
            android:backgroundTint="#673AB7" />

    </LinearLayout>

</ScrollView>