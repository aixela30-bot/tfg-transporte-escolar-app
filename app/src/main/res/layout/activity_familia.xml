<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#E3F2FD">

    <TextView
        android:id="@+id/txtTituloFamilia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panel Familia"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#0D47A1"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/txtEstadoMenor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estado del menor"
        android:textSize="18sp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/txtNotificacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Notificación"
        android:textSize="18sp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/txtUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ubicación"
        android:textSize="18sp"
        android:layout_marginBottom="28dp" />

    <Button
        android:id="@+id/btnVerUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver ubicación GPS"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnActualizar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualizar datos"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />
</LinearLayout>