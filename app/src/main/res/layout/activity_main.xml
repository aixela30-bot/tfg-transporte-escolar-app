<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#E3F2FD">

    <!-- LOGO -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/logo_transporte_escolar"
        android:contentDescription="Logo Transporte Escolar"
        android:layout_marginBottom="20dp" />

    <!-- TÍTULO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transporte Escolar"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#0D47A1"
        android:layout_marginBottom="40dp"/>

    <!-- BOTÓN CUIDADOR -->
    <Button
        android:id="@+id/btnCuidador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Panel Cuidador"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"/>

    <!-- BOTÓN FAMILIA -->
    <Button
        android:id="@+id/btnFamilia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Panel Familia"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"/>

    <!-- BOTÓN CERRAR SESIÓN -->
    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar sesión"
        android:textSize="18sp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"/>

</LinearLayout>