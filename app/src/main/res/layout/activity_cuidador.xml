<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#E3F2FD"
    tools:context=".CuidadorActivity">

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panel del Cuidador"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#0D47A1"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnListaMenores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver lista de menores"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnRutaGps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver ruta GPS"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnEnviarNotificacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enviar notificación"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnVerIncidencias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver incidencias"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        android:padding="12dp" />


    <Button
        android:id="@+id/btnHistorialRutas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Historial de rutas"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        android:padding="12dp" />

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver"
        android:textSize="18sp"
        android:padding="12dp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF" />

</LinearLayout>